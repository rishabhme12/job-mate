{
  "manifest_version": 3,
  "name": "JobMate - AI Job Tagger",
  "version": "1.0.0",
  "description": "Tag LinkedIn jobs with their engineering type using on-device AI.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/feed/*"
      ],
      "run_at": "document_end",
      "js": ["storage.js", "filter_engine.js", "ui_control_bar.js", "keyword_engine.js", "content.js"],
      "css": ["styles.css"]
    }
  ]
}
